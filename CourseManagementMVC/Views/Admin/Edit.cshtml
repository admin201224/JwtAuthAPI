@model CourseManagementMVC.Models.EditUserViewModel
@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
}

<div class="card-premium p-5" style="max-width: 600px; margin: 0 auto;">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3 border-secondary" style="border-color: rgba(255, 255, 255, 0.08) !important;">
        <h2 class="text-white font-weight-bold mb-1">Cập nhật tài khoản</h2>
        <a asp-action="Users" class="btn btn-outline-light btn-sm"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
    </div>

    <form asp-action="Edit" method="post">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }
        
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Username" class="form-label text-secondary fw-bold"></label>
            <input asp-for="Username" class="form-control bg-dark text-white border-secondary" required />
            <span asp-validation-for="Username" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label text-secondary fw-bold"></label>
            <input asp-for="Password" type="password" class="form-control bg-dark text-white border-secondary" placeholder="Nhập để đổi mật khẩu mới" />
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Role" class="form-label text-secondary fw-bold"></label>
            <select asp-for="Role" class="form-select bg-dark text-white border-secondary">
                <option value="Student">Học viên (Student)</option>
                <option value="Instructor">Giảng viên (Instructor)</option>
                <option value="Admin">Quản trị viên (Admin)</option>
            </select>
            <span asp-validation-for="Role" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm" style="background: var(--primary-gradient); border: none;">
            <i class="fa-solid fa-save me-1"></i> Lưu thay đổi
        </button>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
