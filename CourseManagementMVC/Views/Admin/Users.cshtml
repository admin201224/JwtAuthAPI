@model IEnumerable<CourseManagementMVC.Models.UserViewModel>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="card-premium p-5">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3 border-secondary" style="border-color: rgba(255, 255, 255, 0.08) !important;">
        <div>
            <h2 class="text-white font-weight-bold mb-1">Quản lý Người dùng</h2>
            <p class="text-secondary mb-0">Hệ thống có tổng cộng <strong class="text-white">@Model.Count()</strong> người dùng</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary fw-bold text-white shadow-sm" style="background: var(--primary-gradient); border: none;">
                <i class="fa-solid fa-plus me-2"></i> Thêm người dùng
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-users fa-3x text-secondary mb-3"></i>
            <h4 class="text-white">Chưa có dữ liệu</h4>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle border-secondary" style="background: transparent;">
                <thead>
                    <tr class="text-secondary small text-uppercase" style="border-bottom-color: rgba(255, 255, 255, 0.08) !important;">
                        <th>ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Ngày tạo</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr style="border-bottom-color: rgba(255, 255, 255, 0.05) !important;">
                            <td class="text-secondary">#@user.Id</td>
                            <td class="text-white font-weight-semibold">@user.Username</td>
                            <td class="text-secondary">@user.Email</td>
                            <td>
                                @{
                                    var badgeClass = user.Role switch
                                    {
                                        "Admin" => "bg-danger",
                                        "Instructor" => "bg-info",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@user.Role</span>
                            </td>
                            <td class="text-secondary small">
                                @(user.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-dark-glass" title="Sửa thông tin"><i class="fa-solid fa-edit"></i></a>
                                    @if (user.Username != User.Identity.Name) // Don't allow deleting self
                                    {
                                        <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?');">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger text-white" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
