@{
    ViewData["Title"] = "EdTech Hub - Nền tảng học tập trực tuyến hàng đầu";
}

<!-- Hero Section -->
<div class="details-banner py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h1 class="display-4 font-weight-extrabold text-white mb-4" style="font-weight: 800; line-height: 1.2;">
                    Nâng cao kỹ năng của bạn với các khóa học chất lượng cao
                </h1>
                <p class="lead text-light opacity-75 mb-4" style="font-size: 1.1rem;">
                    Khám phá hàng ngàn khóa học từ các chuyên gia hàng đầu ngành. Học tập theo tốc độ của bạn, bất cứ lúc nào, bất cứ nơi đâu.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-premium btn-lg">
                        <i class="fa-solid fa-arrow-right me-2"></i> Khám phá khóa học
                    </a>
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg">
                            <i class="fa-solid fa-user-plus me-2"></i> Đăng ký miễn phí
                        </a>
                    }
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <div class="card-premium p-5">
                    <i class="fa-solid fa-graduation-cap fa-5x text-purple mb-3"></i>
                    <h3 class="text-white font-weight-bold">Bắt đầu học ngay</h3>
                    <p class="text-secondary">Hàng ngàn khóa học đang chờ bạn</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container my-5">
    <div class="text-center mb-5">
        <h2 class="text-white font-weight-bold mb-3" style="font-size: 2rem;">Tại sao chọn chúng tôi?</h2>
        <p class="text-secondary lead">Các tính năng vượt trội giúp bạn thành công</p>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card-premium p-4 text-center h-100">
                <i class="fa-solid fa-laptop fa-3x text-purple mb-3"></i>
                <h5 class="text-white font-weight-bold mb-2">Học online 24/7</h5>
                <p class="text-secondary mb-0">Truy cập khóa học của bạn bất cứ lúc nào, từ bất kỳ nơi đâu</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-premium p-4 text-center h-100">
                <i class="fa-solid fa-certificate fa-3x text-pink mb-3"></i>
                <h5 class="text-white font-weight-bold mb-2">Chứng chỉ chính thức</h5>
                <p class="text-secondary mb-0">Nhận chứng chỉ khi hoàn thành khóa học</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-premium p-4 text-center h-100">
                <i class="fa-solid fa-users fa-3x text-info mb-3"></i>
                <h5 class="text-white font-weight-bold mb-2">Cộng đồng sôi động</h5>
                <p class="text-secondary mb-0">Kết nối với hàng triệu học viên trên toàn thế giới</p>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="details-banner py-5">
    <div class="container">
        <div class="card-premium p-5 text-center">
            <h2 class="text-white font-weight-bold mb-3">Bắt đầu hành trình học tập của bạn hôm nay</h2>
            <p class="text-secondary lead mb-4">Tham gia hàng triệu học viên đã thay đổi cuộc sống của họ</p>
            <a asp-controller="Courses" asp-action="Index" class="btn btn-premium btn-lg">
                Khám phá ngay <i class="fa-solid fa-arrow-right ms-2"></i>
            </a>
        </div>
    </div>
</div>
