<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EdTech Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CourseManagementMVC.styles.css" asp-append-version="true" />
    <!-- FontAwesome for beautiful icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class ="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Courses" asp-action="Index">
                    <i class="fa-solid fa-graduation-cap text-purple"></i>
                    <span>EDTECH HUB</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light px-3" asp-controller="Courses" asp-action="Index">
                                <i class="fa-solid fa-book-open me-1"></i> Khóa học
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light px-3" asp-controller="MyCourses" asp-action="Index">
                                    <i class="fa-solid fa-chalkboard-user me-1"></i> Khóa của tôi
                                </a>
                            </li>
                            @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light px-3" asp-controller="Dashboard" asp-action="Index">
                                        <i class="fa-solid fa-chart-pie me-1"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light px-3" asp-controller="Courses" asp-action="Create">
                                        <i class="fa-solid fa-plus-circle me-1"></i> Tạo khóa học
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light px-3" asp-controller="Admin" asp-action="Users">
                                        <i class="fa-solid fa-users-gear me-1"></i> Quản lý User
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Học viên";
                            var displayRole = role switch {
                                "Admin" => "Quản trị viên",
                                "Instructor" => "Giảng viên",
                                _ => "Học viên"
                            };
                            
                            <li class="nav-item text-light d-flex align-items-center gap-2">
                                <div class="text-end">
                                    <span class="d-block font-weight-bold text-white small">@User.Identity.Name</span>
                                    <span class="badge bg-purple small text-white" style="font-size: 0.65rem; background: var(--primary-gradient);">@displayRole</span>
                                </div>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-dark-glass py-2 px-3 btn-sm">
                                        <i class="fa-solid fa-arrow-right-from-bracket me-1"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-premium btn-sm py-2 px-3" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 mb-5 flex-grow-1">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="background: rgba(16, 185, 129, 0.15); color: #10b981; border-radius: 12px;">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="background: rgba(244, 63, 94, 0.15); color: #f43f5e; border-radius: 12px;">
                <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto">
        <div class="container text-center">
            <span class="text-secondary small"></span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
