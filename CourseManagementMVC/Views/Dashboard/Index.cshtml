@model CourseManagementMVC.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Tổng quan";
}

<div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom border-secondary" style="border-color: rgba(255, 255, 255, 0.08) !important;">
    <div>
        <h2 class="text-white font-weight-bold mb-1">Dashboard</h2>
        <p class="text-secondary mb-0">Xin chào, <strong class="text-white">@User.Identity.Name</strong>! Đây là tổng quan hệ thống.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Courses" asp-action="Create" class="btn btn-premium btn-sm">
            <i class="fa-solid fa-plus me-1"></i> Tạo khóa học
        </a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Users" class="btn btn-dark-glass btn-sm">
                <i class="fa-solid fa-users me-1"></i> Quản lý người dùng
            </a>
        }
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card-premium p-4 d-flex align-items-center gap-4 h-100">
            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; background: rgba(99, 102, 241, 0.15); color: #6366f1;">
                <i class="fa-solid fa-book-open fa-2x"></i>
            </div>
            <div>
                <p class="text-secondary mb-1 font-weight-semibold text-uppercase small">Tổng khóa học</p>
                <h3 class="text-white font-weight-bold mb-0">@Model.TotalCourses</h3>
            </div>
        </div>
    </div>
    
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-4">
            <div class="card-premium p-4 d-flex align-items-center gap-4 h-100">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; background: rgba(16, 185, 129, 0.15); color: #10b981;">
                    <i class="fa-solid fa-users fa-2x"></i>
                </div>
                <div>
                    <p class="text-secondary mb-1 font-weight-semibold text-uppercase small">Tổng người dùng</p>
                    <h3 class="text-white font-weight-bold mb-0">@Model.TotalUsers</h3>
                </div>
            </div>
        </div>
    }

    <div class="col-md-4">
        <div class="card-premium p-4 d-flex align-items-center gap-4 h-100">
            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; background: rgba(244, 63, 94, 0.15); color: #f43f5e;">
                <i class="fa-solid fa-graduation-cap fa-2x"></i>
            </div>
            <div>
                <p class="text-secondary mb-1 font-weight-semibold text-uppercase small">Tổng lượt đăng ký</p>
                <h3 class="text-white font-weight-bold mb-0">@Model.TotalEnrollments</h3>
            </div>
        </div>
    </div>
</div>

<div class="card-premium p-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="text-white font-weight-bold mb-0">Khóa học gần đây</h4>
        <a asp-controller="Courses" asp-action="Index" class="btn btn-dark-glass btn-sm">Xem tất cả</a>
    </div>

    @if (!Model.RecentCourses.Any())
    {
        <div class="text-center py-4">
            <p class="text-secondary mb-0">Chưa có khóa học nào.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle border-secondary mb-0" style="background: transparent;">
                <thead>
                    <tr class="text-secondary small text-uppercase" style="border-bottom-color: rgba(255, 255, 255, 0.08) !important;">
                        <th>Khóa học</th>
                        <th>Trạng thái</th>
                        <th>Giá</th>
                        <th>Thời lượng</th>
                        <th>Ngày tạo</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model.RecentCourses)
                    {
                        <tr style="border-bottom-color: rgba(255, 255, 255, 0.05) !important;">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                                    {
                                        <img src="@course.ThumbnailUrl" alt="Thumbnail" class="rounded object-fit-cover" style="width: 48px; height: 36px;" />
                                    }
                                    else
                                    {
                                        <div class="rounded d-flex align-items-center justify-content-center bg-secondary bg-opacity-25" style="width: 48px; height: 36px;">
                                            <i class="fa-solid fa-image text-secondary"></i>
                                        </div>
                                    }
                                    <span class="text-white font-weight-semibold">@course.Title</span>
                                </div>
                            </td>
                            <td>
                                @{
                                    var statusClass = course.Status switch
                                    {
                                        "Published" => "bg-success",
                                        "Draft" => "bg-secondary",
                                        "Archived" => "bg-warning",
                                        _ => "bg-primary"
                                    };
                                }
                                <span class="badge @statusClass">@course.Status</span>
                            </td>
                            <td class="text-secondary">@course.Price.ToString("N0") VNĐ</td>
                            <td class="text-secondary">@course.DurationHours giờ</td>
                            <td class="text-secondary small">@(course.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-dark-glass" title="Chi tiết">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                                    {
                                        <a asp-controller="Courses" asp-action="CourseRoster" asp-route-id="@course.Id" class="btn btn-sm btn-dark-glass" title="Danh sách học viên">
                                            <i class="fa-solid fa-users"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
