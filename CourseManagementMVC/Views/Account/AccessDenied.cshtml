@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="row justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="col-md-6 text-center">
        <div class="card-premium p-5">
            <i class="fa-solid fa-circle-xmark fa-4x text-danger mb-4"></i>
            <h1 class="font-weight-extrabold text-white mb-2">Không có quyền truy cập</h1>
            <p class="text-secondary mb-4">Bạn không có quyền xem trang này. Vui lòng liên hệ với quản trị viên hoặc sử dụng tài khoản khác có quyền cao hơn.</p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Courses" asp-action="Index" class="btn btn-premium">
                    <i class="fa-solid fa-house me-1"></i> Quay về trang chủ
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-dark-glass">
                    <i class="fa-solid fa-right-to-bracket me-1"></i> Đăng nhập tài khoản khác
                </a>
            </div>
        </div>
    </div>
</div>
