@model CourseManagementMVC.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-5">
        <div class="card-premium p-5">
            <div class="text-center mb-4">
                <i class="fa-solid fa-graduation-cap fa-3x mb-3 text-purple" style="background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                <h2 class="font-weight-extrabold text-white">Chào mừng trở lại</h2>
                <p class="text-secondary">Đăng nhập tài khoản EdTech Hub của bạn</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-4">
                    <label asp-for="Username" class="form-label form-label-custom"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary text-secondary" style="border-radius: 12px 0 0 12px; border-color: rgba(255, 255, 255, 0.08) !important;">
                            <i class="fa-solid fa-user"></i>
                        </span>
                        <input asp-for="Username" class="form-control form-glass border-start-0" style="border-radius: 0 12px 12px 0 !important;" placeholder="Nhập tên đăng nhập..." required />
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label form-label-custom"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary text-secondary" style="border-radius: 12px 0 0 12px; border-color: rgba(255, 255, 255, 0.08) !important;">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <input asp-for="Password" class="form-control form-glass border-start-0" style="border-radius: 0 12px 12px 0 !important;" placeholder="Nhập mật khẩu..." required />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-premium w-100 py-3 mt-2">
                    Đăng nhập <i class="fa-solid fa-arrow-right ms-1"></i>
                </button>
            </form>

            <div class="text-center mt-4">
                <p class="text-secondary small mb-0">
                    Chưa có tài khoản? 
                    <a asp-action="Register" class="text-white font-weight-bold" style="text-decoration: none;">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
